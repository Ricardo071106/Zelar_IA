# Tools
ENABLE_WHATSAPP_BOT=true
# Telegram: defina false para não iniciar polling (evita 409 com outra instância / use só WhatsApp)
TELEGRAM_BOT_ENABLED=true
REQUIRE_TELEGRAM=false
WHATSAPP_AUTH_DIR=./server/whatsapp/auth_info_baileys

# Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Microsoft
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_AUDIO_MODEL=openrouter/free
OPENROUTER_AUDIO_FALLBACK_MODEL=openrouter/free
AUDIO_TRANSCRIPTION_AUDIT_LOG=false

# SMTP (opcional, alternativa gratuita ao SendGrid - ex: Gmail App Password)
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PAYMENT_LINK=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# Application URLs
BASE_URL=http://localhost:8080
# Segredo longo e aleatório para assinar links do painel web (/painel) — obrigatório em produção
PANEL_TOKEN_SECRET=
# Opcional: user.id numérico + linha em system_calendar_integrations (integration_key abaixo)
DEFAULT_ORGANIZER_USER_ID=
DEFAULT_ORGANIZER_INTEGRATION_KEY=default_google_organizer
# Conta Google Zelar no banco: integration_key padrão zelar_google_invites + tokens JSON na tabela
ZELAR_CALENDAR_INTEGRATION_KEY=zelar_google_invites
# ID interno só para cache OAuth (não precisa existir em users)
ZELAR_CALENDAR_OAUTH_USER_ID=999001
RESTART_WEBHOOK_TOKEN=
RESTART_WEBHOOK_URL=
AUTO_RESTART_AT_MIDNIGHT=false
AUTO_RESTART_TZ=America/Sao_Paulo
AUTO_RESTART_CRON=0 0 * * *

# Others
# Com TELEGRAM_BOT_ENABLED=false o token é ignorado e o bot não sobe
TELEGRAM_BOT_TOKEN=
DATABASE_URL=